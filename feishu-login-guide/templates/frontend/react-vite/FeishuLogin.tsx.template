// 飞书登录组件（React + TypeScript）
//
// ⚠️ 跨项目统一视觉规范实现。不要修改样式、文案、尺寸、配色。
// 视觉规范源：assets/login-ui-spec.md
// 飞书 logo：inline SVG（已嵌在本文件，无需外部引用）
// FBIF logo：从 /fbif-logo.webp 加载（部署时把 assets/fbif-logo.webp 放到项目 public/ 目录）
//
// 提供 4 个组件：
//   <FeishuLoginPage />     — drop-in 的整页登录（默认用这个）
//   <FeishuLoginButton />   — 单个按钮（已有自定义登录页时用）
//   <RequireAuth />         — 包受保护路由
//   <FeishuUserBadge />     — 顶栏当前用户徽标
//
// 后端约定（跨项目一致）：
//   - GET  /auth/feishu/login    后端 302 跳飞书授权页
//   - GET  /auth/feishu/callback 后端处理回调
//   - GET  /api/me               返当前用户 JSON，未登录返 401
//   - POST /auth/feishu/logout   退出登录

import React, { useEffect, useState } from 'react';

const LOGIN_URL = '/auth/feishu/login';
const LOGOUT_URL = '/auth/feishu/logout';
const ME_URL = '/api/me';

// FBIF 品牌色（不要修改）
const FBIF = {
  blue: '#145078',     // 主色（深海蓝）
  blueDark: '#0F3D5C', // hover/active
  yellow: '#F0C800',   // 强调色（仅 logo 内的感叹号用，UI 上少用）
} as const;

// 飞书品牌色
const FEISHU = {
  blue: '#3370FF',
} as const;

// ========== FBIF Logo 组件（用 webp 静态资源） ==========

function FbifLogo({ size = 80, alt = 'FBIF' }: { size?: number; alt?: string }) {
  return (
    <img
      src="/fbif-logo.webp"
      alt={alt}
      width={size}
      height={size}
      style={{ display: 'block', objectFit: 'contain' }}
    />
  );
}

