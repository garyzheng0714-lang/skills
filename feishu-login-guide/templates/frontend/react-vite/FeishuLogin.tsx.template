// ========== 单按钮（自定义页面用） ==========

export function FeishuLoginButton({
  size = 'md',
  loading = false,
  disabled = false,
  fullWidth = false,
  label,
  className,
}: {
  size?: Size;
  loading?: boolean;
  disabled?: boolean;
  fullWidth?: boolean;
  label?: string;
  className?: string;
}) {
  const s = SIZE[size];
  const isDisabled = loading || disabled;
  const text = loading ? '跳转中...' : label ?? '使用 FBIF 登录';

  return (
    <a
      href={isDisabled ? undefined : LOGIN_URL}
      className={className}
      role="button"
      aria-disabled={isDisabled}
      style={{
        display: fullWidth ? 'flex' : 'inline-flex',
        width: fullWidth ? '100%' : undefined,
        alignItems: 'center',
        justifyContent: 'center',
        gap: 10,
        padding: s.padding,
        height: s.height,
        background: FBIF.blue,
        color: '#FFFFFF',
        borderRadius: 8,
        textDecoration: 'none',
        fontWeight: 500,
        fontSize: s.fontSize,
        lineHeight: 1,
        userSelect: 'none',
        cursor: isDisabled ? 'not-allowed' : 'pointer',
        opacity: isDisabled ? 0.5 : 1,
        transition: 'background 0.15s ease, transform 0.05s ease',
        whiteSpace: 'nowrap',
        boxSizing: 'border-box',
      }}
      onMouseEnter={(e) => {
        if (!isDisabled) e.currentTarget.style.background = FBIF.blueDark;
      }}
      onMouseLeave={(e) => {
        if (!isDisabled) e.currentTarget.style.background = FBIF.blue;
      }}
      onMouseDown={(e) => {
        if (!isDisabled) e.currentTarget.style.transform = 'scale(0.99)';
      }}
      onMouseUp={(e) => {
        if (!isDisabled) e.currentTarget.style.transform = 'scale(1)';
      }}
    >
      <FeishuLogo size={s.logo} />
      <span>{text}</span>
    </a>
  );
}

// ========== 当前用户 hook ==========

export function useCurrentUser(): CurrentUser | null | undefined {
  // undefined = 加载中 | null = 未登录 | CurrentUser = 已登录
  const [user, setUser] = useState<CurrentUser | null | undefined>(undefined);

  useEffect(() => {
    let cancelled = false;
    fetch(ME_URL, { credentials: 'include' })
      .then((res) => {
        if (cancelled) return;
        if (res.status === 401) {
          setUser(null);
          return null;
        }
        return res.json();
      })
      .then((data) => {
        if (cancelled || !data) return;
        setUser(data);
      })
      .catch(() => {
        if (!cancelled) setUser(null);
      });
    return () => {
      cancelled = true;
    };
  }, []);

  return user;
}

// ========== 保护路由 ==========

export function RequireAuth({
  children,
  fallback,
  loginPath = '/login',
}: {
  children: React.ReactNode;
  fallback?: React.ReactNode;
  loginPath?: string;
}) {
  const user = useCurrentUser();
  if (user === undefined) return <>{fallback ?? <div style={{ padding: 40, textAlign: 'center', color: '#5A6B80' }}>加载中...</div>}</>;
  if (user === null) {
    window.location.href = loginPath;
    return null;
  }
  return <>{children}</>;
}

// ========== 顶栏当前用户 ==========

export function FeishuUserBadge({ size = 32 }: { size?: number }) {
  const user = useCurrentUser();

  if (user === undefined || user === null) return null;

  return (
    <div style={{ display: 'inline-flex', alignItems: 'center', gap: 8 }}>
      {user.avatar_url && (
        <img
          src={user.avatar_url}
          alt={user.name}
          width={size}
          height={size}
          style={{ borderRadius: '50%' }}
        />
      )}
      <span style={{ fontSize: 14, fontWeight: 500, color: '#0F1F33' }}>{user.name}</span>
      <button
        onClick={async () => {
          await fetch(LOGOUT_URL, { method: 'POST', credentials: 'include' });
          window.location.href = '/';
        }}
        style={{
          marginLeft: 8,
          padding: '4px 10px',
          fontSize: 12,
          background: 'transparent',
          border: '1px solid #E5E9F0',
          borderRadius: 4,
          color: '#5A6B80',
          cursor: 'pointer',
        }}
        onMouseEnter={(e) => {
          e.currentTarget.style.background = '#F5F7FA';
        }}
        onMouseLeave={(e) => {
          e.currentTarget.style.background = 'transparent';
        }}
      >
        退出
      </button>
    </div>
  );
}
