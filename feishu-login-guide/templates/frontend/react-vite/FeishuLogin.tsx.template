// ========== 类型定义 ==========

export interface CurrentUser {
  name: string;
  email?: string;
  avatar_url?: string;
  open_id?: string;
}

const SIZE = {
  sm: { height: 36, fontSize: 13, logo: 16, padding: '0 14px' },
  md: { height: 44, fontSize: 14, logo: 20, padding: '0 18px' },
  lg: { height: 52, fontSize: 15, logo: 22, padding: '0 22px' },
} as const;

type Size = keyof typeof SIZE;

